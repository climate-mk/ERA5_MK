# Direct Line secret for Microsoft Copilot Studio bot (keep secret - never commit .env file)
DIRECT_LINE_SECRET=your_direct_line_secret_here

# SerpApi key (serpapi.com) — optional, used by climate_news.py to pull
# additional Macedonian climate-news results from Google News search.
# Leave unset to skip this source (the other 21 RSS/Bluesky sources still work).
SERPAPI_KEY=your_serpapi_key_here
